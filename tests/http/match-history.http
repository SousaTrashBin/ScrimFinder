# @name Filter by matches where some team had at least 20 kills

GET {{baseUrl}}/matches?page=0&size=20

{
    "teams": [
        {
            "teamKills": {
                "min": 20
            }
        }
    ]
}

### Above match has team blue with 13 kills and team red with 35 kills
# @name Filter by matches where some team had at least 20 kills and team blue had at most 15 kills and between 30 and 40 deaths

GET {{baseUrl}}/matches?page=0&size=20

{
    "teams": [
        {
            "teamKills": {
                "min": 20
            }
        },
        {
            "teamSide": "BLUE",
            "teamKills": {
                "max": 15
            },
            "teamDeaths": {
                "min": 30,
                "max": 40
            }
        }
    ]
}

###
# @name Filter by matches that have a player on the blue team and a player that won on the red team

GET {{baseUrl}}/matches?page=0&size=20

