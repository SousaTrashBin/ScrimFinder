###
# @name GET match 1

GET {{baseUrl}}/matches/{{matchId1}}
Accept: application/json
Content-Type: application/json

###
# @name Filter empty

GET {{baseUrl}}/matches?page=0&size=20

###
# @name Filter by queueId = aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa

GET {{baseUrl}}/matches?page=0&size=20

{
    "queueId": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
}

###
# @name Filter by queueId = baaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaab (no match)

GET {{baseUrl}}/matches?page=0&size=20

{
    "queueId": "baaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaab"
}

###
# @name Filter by time >= 10000

GET {{baseUrl}}/matches?page=0&size=20

{
    "time": {
        "min": 10000
    }
}

