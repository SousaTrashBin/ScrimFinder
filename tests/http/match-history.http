{
    "players": [
        {
            "playerName": "Last dance",
            "role": "SUPPORT",
            "teamSide": "BLUE",
            "healing": {
                "max": 5000
            }
        },
        {
            "playerName": "berebooo",
            "won": true,
            "kills": {
                "min": 1,
                "max": 1
            },
            "gold": {
                "min": 8000
            }
        }
    ]
}

###
# @name Filter by matches where someone played as champion ASHE and player Fentasm played as one of the following champions: VAYNE, DIANA or JAX

