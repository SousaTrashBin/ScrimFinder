# If running in the cloud, replace "match-history-service:8080" with EXTERNAL_IP
# obtained from the terminal after deploying or with "kubectl get svc scrimfinder-traefik -n scrimfinder"
@baseUrl = http://match-history-service:8080/api/v1/history

@matchId1 = EUW1_7779779801
@matchId2 = EUW1_7798917216
@matchId3 = EUW1_7794855675
@matchId4 = EUW1_7799338678
@matchId5 = EUW1_7793513696
@matchId6 = EUW1_7797556115

###
