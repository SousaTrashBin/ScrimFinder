  "paths" : {
    "/api/v1/history/matches" : {
      "get" : {
        "summary" : "Get paginated match history with filters and sorting",
        "operationId" : "getMatches",
        "tags" : [ "Match History" ],
        "parameters" : [ {
          "description" : "0-based page index",
          "example" : 0,
          "name" : "page",
          "in" : "query",
          "schema" : {
            "type" : "integer",
            "format" : "int32",
            "default" : 0
          }
        }, {
          "description" : "Page size (1..100)",
          "example" : 20,
          "name" : "size",
          "in" : "query",
          "schema" : {
            "type" : "integer",
            "format" : "int32",
            "maximum" : 100,
            "minimum" : 1,
            "default" : 20
          }
        } ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/MatchFilters"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "Successfully retrieved filtered matches",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/PaginatedResponseDTO"
                }
              }
            }
          },
          "400" : {
            "description" : "Invalid query or pagination parameters",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "408" : {
            "description" : "Request timeout",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/history/matches/{riotMatchId}" : {
      "get" : {
        "summary" : "Get simplified match information by ID",
        "operationId" : "getMatchById",
        "tags" : [ "Match History" ],
        "parameters" : [ {
          "description" : "Riot match id in REGION_MATCHID format",
          "example" : "VN_1417849076",
          "name" : "riotMatchId",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "string",
            "pattern" : "\\S"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "Successfully retrieved the match details",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/MatchDTO"
                }
              }
            }
          },
          "404" : {
            "description" : "Match not found",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "408" : {
            "description" : "Request timeout",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500" : {
            "description" : "Internal error in communicating with other services",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503" : {
            "description" : "Some of the needed servers cannot process requests",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
