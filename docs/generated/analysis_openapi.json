{
  "openapi": "3.1.0",
  "info": {
    "title": "ScrimFinder Analysis Service",
    "description": "\n    Real-time draft, build, player performance and champion analysis.\n\n    \n**Student:** Rodrigo Neto (fc59850)\n    ",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/analysis/draft": {
      "post": {
        "tags": [
          "Analysis"
        ],
        "summary": "Win probability for a 5v5 draft",
        "description": "Returns ML-predicted win probabilities for both teams, plus synergy analysis, counter matchups, and win conditions. Requires an active draft model.",
        "operationId": "analyze_draft_api_v1_analysis_draft_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DraftAnalysisRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DraftAnalysisResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analysis/build": {
      "post": {
        "tags": [
          "Analysis"
        ],
        "summary": "Build effectiveness score (0\u2013100)",
        "description": "Scores an item build for a champion using the trained build model. Score is derived from predicted win probability. Optionally considers enemy composition for alternative suggestions.",
        "operationId": "analyze_build_api_v1_analysis_build_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BuildAnalysisRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuildAnalysisResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analysis/player": {
      "post": {
        "tags": [
          "Analysis"
        ],
        "summary": "Player performance analysis and improvement tips",
        "description": "Aggregates a player's recent match stats and benchmarks each metric against the EUW population for their role using stored percentile data. Returns prioritised improvement tips.",
        "operationId": "analyze_player_api_v1_analysis_player_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlayerAnalysisRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerAnalysisResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analysis/game": {
      "post": {
        "tags": [
          "Analysis"
        ],
        "summary": "Post-game breakdown for all 10 players",
        "description": "Scores each player's performance using the performance model. Supply a `game_id` (stored game) or inline `raw_data`. Participants must have: puuid, championId, teamId, position, win, kills, deaths, assists, gold, cs, dmg_champs, vision, kda, kp.",
        "operationId": "analyze_game_api_v1_analysis_game_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GameAnalysisRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameAnalysisResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analysis/champion": {
      "post": {
        "tags": [
          "Analysis"
        ],
        "summary": "Champion stats from EUW dataset",
        "description": "Returns win rate, pick rate, average stats, and counter data for a champion. Queries the EUW dataset directly \u2014 no model required.",
        "operationId": "analyze_champion_api_v1_analysis_champion_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChampionAnalysisRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChampionAnalysisResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analysis/": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Root",
        "operationId": "root_api_v1_analysis__get",
