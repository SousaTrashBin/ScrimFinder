    }
  },
  "components": {
    "schemas": {
      "AlternativeItem": {
        "properties": {
          "replaces": {
            "type": "string",
            "title": "Replaces"
          },
          "suggested_item": {
            "type": "string",
            "title": "Suggested Item"
          },
          "reason": {
            "type": "string",
            "title": "Reason"
          }
        },
        "type": "object",
        "required": [
          "replaces",
          "suggested_item",
          "reason"
        ],
        "title": "AlternativeItem"
      },
      "BuildAnalysisRequest": {
        "properties": {
          "champion": {
            "type": "string",
            "title": "Champion"
          },
          "role": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Role"
              },
              {
                "type": "null"
              }
            ]
          },
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Items"
          },
          "enemy_composition": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Enemy Composition"
          },
          "model_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Id"
          }
        },
        "type": "object",
        "required": [
          "champion",
          "items"
        ],
        "title": "BuildAnalysisRequest"
      },
      "BuildAnalysisResponse": {
        "properties": {
          "champion": {
            "type": "string",
            "title": "Champion"
          },
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Items"
          },
          "score": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Score"
          },
          "win_rate_with_build": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Win Rate With Build"
          },
          "strengths": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Strengths"
          },
          "weaknesses": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Weaknesses"
          },
          "alternative_items": {
            "items": {
              "$ref": "#/components/schemas/AlternativeItem"
            },
            "type": "array",
            "title": "Alternative Items"
          },
          "model_version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Version"
          }
        },
        "type": "object",
        "required": [
          "champion",
          "items",
          "score",
          "win_rate_with_build",
          "strengths",
          "weaknesses",
          "alternative_items",
          "model_version"
        ],
        "title": "BuildAnalysisResponse"
      },
      "ChampionAnalysisRequest": {
        "properties": {
          "champion": {
            "type": "string",
            "title": "Champion"
          },
          "position": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Position"
          },
          "patch": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Patch"
          },
          "match_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Match Type"
          },
          "model_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Id"
          }
        },
        "type": "object",
        "required": [
          "champion"
        ],
        "title": "ChampionAnalysisRequest"
      },
      "ChampionAnalysisResponse": {
        "properties": {
          "champion": {
            "type": "string",
            "title": "Champion"
          },
          "stats": {
            "$ref": "#/components/schemas/ChampionStats"
          },
          "tier": {
            "type": "string",
            "title": "Tier"
          },
          "model_version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Version"
          }
        },
        "type": "object",
        "required": [
          "champion",
          "stats",
          "tier",
          "model_version"
        ],
        "title": "ChampionAnalysisResponse"
      },
      "ChampionInDraft": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          }
        },
        "type": "object",
        "required": [
          "name",
          "role"
        ],
        "title": "ChampionInDraft"
      },
      "ChampionStats": {
        "properties": {
          "champion": {
            "type": "string",
            "title": "Champion"
          },
          "position": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Position"
          },
          "win_rate": {
            "type": "number",
            "title": "Win Rate"
          },
          "pick_rate": {
            "type": "number",
            "title": "Pick Rate"
          },
          "total_games": {
            "type": "integer",
            "title": "Total Games"
          },
          "avg_kda": {
            "type": "number",
            "title": "Avg Kda"
          },
          "avg_damage": {
            "type": "number",
            "title": "Avg Damage"
          },
          "avg_gold": {
            "type": "number",
            "title": "Avg Gold"
          },
          "avg_cs": {
            "type": "number",
            "title": "Avg Cs"
          },
          "avg_vision": {
            "type": "number",
            "title": "Avg Vision"
          },
          "best_items": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Best Items"
          },
          "best_runes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Best Runes"
          },
          "counters": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Counters"
          },
          "countered_by": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Countered By"
          }
        },
        "type": "object",
        "required": [
          "champion",
          "position",
          "win_rate",
          "pick_rate",
          "total_games",
          "avg_kda",
          "avg_damage",
          "avg_gold",
          "avg_cs",
          "avg_vision",
          "best_items",
          "best_runes",
          "counters",
          "countered_by"
        ],
        "title": "ChampionStats"
      },
      "Concern": {
        "type": "string",
        "enum": [
          "draft",
          "build",
          "performance"
        ],
        "title": "Concern"
      },
      "DraftAnalysisRequest": {
        "properties": {
          "team_blue": {
            "$ref": "#/components/schemas/DraftTeam"
          },
          "team_red": {
            "$ref": "#/components/schemas/DraftTeam"
          },
          "model_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Id"
          }
        },
        "type": "object",
        "required": [
          "team_blue",
          "team_red"
        ],
        "title": "DraftAnalysisRequest"
      },
      "DraftAnalysisResponse": {
        "properties": {
          "blue_win_probability": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Blue Win Probability"
          },
          "red_win_probability": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Red Win Probability"
          },
          "blue_synergies": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Blue Synergies"
          },
          "red_synergies": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Red Synergies"
          },
          "blue_counters": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Blue Counters"
          },
          "red_counters": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Red Counters"
          },
          "win_conditions": {
            "additionalProperties": true,
            "type": "object",
            "title": "Win Conditions"
          },
          "tips": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tips"
          },
          "model_version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Version"
          }
        },
        "type": "object",
        "required": [
          "blue_win_probability",
          "red_win_probability",
          "blue_synergies",
          "red_synergies",
          "blue_counters",
          "red_counters",
          "win_conditions",
          "tips",
          "model_version"
        ],
        "title": "DraftAnalysisResponse"
      },
      "DraftTeam": {
        "properties": {
          "champions": {
            "items": {
              "$ref": "#/components/schemas/ChampionInDraft"
            },
            "type": "array",
            "maxItems": 5,
            "minItems": 1,
            "title": "Champions"
          }
        },
        "type": "object",
        "required": [
          "champions"
        ],
        "title": "DraftTeam"
      },
      "ErrorResponse": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "details": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Details"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ErrorResponse"
      },
      "GameAnalysisRequest": {
        "properties": {
          "game_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Game Id",
            "description": "Game id to analyze. Riot-style values like 'VN_1417849076' are supported. From LeagueOfGraphs URLs, combine region + '_' + id (for example, https://www.leagueofgraphs.com/match/vn/1417849076#participant8 -> VN_1417849076)."
          },
          "raw_data": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw Data"
          },
          "model_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Id"
          },
          "concern": {
            "$ref": "#/components/schemas/Concern",
            "default": "performance"
          }
        },
        "type": "object",
        "title": "GameAnalysisRequest"
      },
      "GameAnalysisResponse": {
        "properties": {
          "game_id": {
            "type": "string",
            "title": "Game Id"
          },
          "patch": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Patch"
          },
          "duration_sec": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Sec"
          },
          "winner": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Winner"
          },
          "players": {
            "items": {
              "$ref": "#/components/schemas/PlayerOutcome"
            },
            "type": "array",
            "title": "Players"
          },
          "team_synergies": {
            "additionalProperties": true,
            "type": "object",
            "title": "Team Synergies"
          },
          "key_moments": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Key Moments"
          },
          "model_version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Version"
          }
        },
        "type": "object",
        "required": [
          "game_id",
          "patch",
          "duration_sec",
          "winner",
          "players",
          "team_synergies",
          "key_moments",
          "model_version"
        ],
        "title": "GameAnalysisResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ImpactLevel": {
        "type": "string",
        "enum": [
          "LOW",
