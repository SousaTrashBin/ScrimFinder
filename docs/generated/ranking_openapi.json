      "get" : {
        "summary" : "Get a player's ranking for a specific queue",
        "operationId" : "getPlayerRankingByQueue",
        "tags" : [ "Player Ranking" ],
        "parameters" : [ {
          "name" : "playerId",
          "in" : "path",
          "required" : true,
          "schema" : {
            "$ref" : "#/components/schemas/UUID"
          }
        }, {
          "name" : "queueId",
          "in" : "path",
          "required" : true,
          "schema" : {
            "$ref" : "#/components/schemas/UUID"
          }
