    "/api/v1/ranking/players/{playerId}/link-lol-account" : {
      "put" : {
        "summary" : "Link a League of Legends account to a player",
        "description" : "For gameName/tagLine discovery, you can use https://www.leagueofgraphs.com/rankings/summoners . Region should be the Riot routing region enum (AMERICAS, EUROPE, ASIA, SEA).",
        "operationId" : "linkLolAccount",
        "tags" : [ "Player Management" ],
        "parameters" : [ {
          "name" : "playerId",
          "in" : "path",
          "required" : true,
          "schema" : {
            "$ref" : "#/components/schemas/UUID"
          }
        } ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/LinkLolAccountRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "Account successfully linked",
            "content" : {
              "application/json" : {
                "schema" : {
